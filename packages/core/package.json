{
  "name": "@spatialdata/core",
  "version": "0.3.0",
  "description": "Core library for interfacing with SpatialData stores",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./workers": {
      "types": "./dist/workers/index.d.ts",
      "default": "./dist/workers.js"
    },
    "./points-worker": {
      "default": "./dist/points-worker.js"
    }
  },
  "files": [
    "dist",
    "vendor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zarrextra": "workspace:*",
    "@math.gl/core": "catalog:",
    "@zarrita/storage": "catalog:",
    "anndata.js": "catalog:",
    "apache-arrow": "catalog:",
    "ol": "^10.6.1",
    "zarrita": "catalog:",
    "zod": "catalog:",
    "earcut": "^3.0.2"
  },
  "overrides": {
    "zarrita": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "typescript": "catalog:",
    "unzipit": "^1.4.3",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Taylor-CCB-Group/SpatialData.js.git",
    "directory": "packages/core"
  }
}
