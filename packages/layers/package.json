{
  "name": "@spatialdata/layers",
  "version": "0.2.5",
  "description": "deck.gl CompositeLayer and versioned SpatialLayerProps for SpatialData rendering",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "deck.gl": "catalog:"
  },
  "dependencies": {
    "@deck.gl/core": "catalog:",
    "@hms-dbmi/viv": "catalog:",
    "@math.gl/core": "catalog:",
    "@spatialdata/core": "workspace:*",
    "zod": "catalog:",
    "@luma.gl/engine": "^9.3.5"
  },
  "devDependencies": {
    "@deck.gl/core": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "deck.gl": "catalog:"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Taylor-CCB-Group/SpatialData.js.git",
    "directory": "packages/layers"
  }
}
